datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  AUDITOR
  COLLABORATOR
}

model Audit {
  id          String   @id @default(uuid())
  title       String
  department  String
  responsible String
  date        DateTime
  createdAt   DateTime @default(now())
}

model Process {
  id          String   @id @default(uuid())
  name        String
  description String?
  createdAt   DateTime @default(now())
}

model ActionPlan {
  id          String   @id @default(uuid())
  title       String
  status      Status
  responsible String
  dueDate     DateTime
}

enum Status {
  PENDING
  IN_PROGRESS
  DONE
}